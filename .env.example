# App Store Connect API
# Get these from App Store Connect > Users and Access > Integrations > App Store Connect API
ASC_KEY_ID=YOUR_KEY_ID
ASC_ISSUER_ID=YOUR_ISSUER_ID
ASC_PRIVATE_KEY_PATH=/path/to/AuthKey_XXXXXXXX.p8

# App Store Connect App
ASC_APP_ID=YOUR_APP_ID
ASC_BUNDLE_ID=com.yourcompany.yourapp
ASC_TEAM_ID=YOUR_TEAM_ID
